external GroupBody
{
String          tag;
GroupList       groupList;
GroupItem       registry;
PLGset          guardSet;
union
    GroupItem       &gMethod(GroupItem);
    GroupItem       &gOp(GroupItem,GroupItem);
    ;
union
    String          gText;
    void            *gPointer;
    ;
union
    Buffer          gBuffer;
    char            gCharacter;
    PLGset          gCharacterSet;
    int             gCount;
    GroupItem       gGroup;
    PLGitem         gItem;
    BitMAP          gMap;
    double          gNumber;
    Object          gObject;
    PLGrgx          gRegex;
    Stak            gStak;
    ;

/******************************************************************************
	Basic incant traits
******************************************************************************/
boolean bools {
    isRule
    isLabel
    noPrint
    data:5[isANY isCHAR isSET isBUFFER isCOUNT isGROUP isITEM isMAP isNUMBER isOBJECT isREGEX isSTAK isSTRING isTOKEN]
    actionType:2[isAction isCoded]
    binType:3[isBIN isCLASS isLIST isREGISTRY]
    fileType:2[isDirectory isExec isFile]
    guarding:2[guarded unGuarded guardInProcess]
    instructType:2[isMethod isOperator]
    isBranch:2[isBreak isContinue isReturn]
    isSorted:2[sortAscending sortDescending]
    methodType:2[immediateACTION parseACTION]

    altered
    debugged
    debugGuard
    deferred
    fLAG
    hasAttributes
    hasListeners
    hasMembers
    invoke
    isArgument
    isAssign
    isCondition
    isIndexed
    isInitialized
    isLiteral
    isLocal
    isMacro
    isPercent
    isPointer
    isShortcut
    isSingleton
    isToggle
    isUnary
    isVirtual
    mergeOn
    negate
    tokened } flags;

/******************************************************************************
	Methods aliases and overloads
******************************************************************************/
    GroupBody();
    GroupBody(String s);
	alias
        bitmap              gMap
        buffer              gBuffer
        character           gCharacter
        characterSet        gCharacterSet
        count				gCount
        group               gGroup
        item				gItem
        method              gMethod
        number				gNumber
        object              gObject
        operat              gOp
        pointer				gPointer
        regex               gRegex
        stak                gStak
        text                gText
        ;
}

