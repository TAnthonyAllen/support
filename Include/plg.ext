external PLGitem
{
String		itemStart;
int			itemLength;
PLGtester	test;
PLGitem		firstComponent,
            next,
			nextTestResult;
char		save;
union
	double		amount;
	void		*value;
    PLGitem     valueItem;
	;
boolean
            noRelease
			exists
			flag1
			flag2
			flag3
			flag4
			isSetPLG
			isEndTag
			isRegex
			noPrint
			released
			;
static Tape itemTape;
static int  plgItemDebug;

	PLGitem(String s);
	PLGitem(String s,int i);
	PLGitem(PLGitem item);
    void            append(PLGitem item);
    String          buildString();
    String          chop(int length);
    int				compare(PLGitem i);
    int				compare(String s);
	void			copyTo(String target);
	void			copyTo(Buffer buffer);
	void			dump();
    PLGitem			find(String s);
    void            free();
    PLGitem			get();
    PLGitem			get(String s);
	PLGitem			removeEnd();
    void			runDeferred();
    static void		setItemStack();
	void			setString(String text);
    String			string();
    void			toBuffer(Buffer b);
    String			toString();
    void			unString();
    overload
        +=  append
        []    get
        %   get
        /   find
        ;
    alias
        floating    flag1
        length      itemLength
        run         runDeferred
        start       itemStart
        new         plgItemFactory
        ;
}

