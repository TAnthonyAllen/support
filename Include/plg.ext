
external regex.h
{
	typedef regex_t;
	typedef reqmatch_t;
	int         REG_EXTENDED,
                REG_ICASE,
                REG_NOSUB;
	int		regcomp(regex_t* m,String s,int f);
	int		regexec(regex_t* m,String s,size_t m,reqmatch_t p,int f);
