external dispatch/dispatch.h local
{
	typedef			dispatch_block_t;
	typedef			dispatch_queue_t;
	typedef			dispatch_group_t;
	typedef			dispatch_time_t;
	int				DISPATCH_QUEUE_PRIORITY_HIGH,
					DISPATCH_QUEUE_PRIORITY_LOW,
					DISPATCH_QUEUE_PRIORITY_DEFAULT;
	unsigned int	DISPATCH_TIME_NOW,
					DISPATCH_TIME_FOREVER;
	alias
		DQ			dispatch_queue_t
		Dgroup		dispatch_group_t
		Dblock		dispatch_block_t
		Dtime		dispatch_time_t
		forever		DISPATCH_TIME_FOREVER
		now			DISPATCH_TIME_NOW
		;
	void		dispatch_after(unsigned int w,DQ q,void ^b());
	void		dispatch_after_f(unsigned int w,DQ q,void *d,void &m(void*));
	void		dispatch_apply(int i,DQ q,void ^b(size_t));
	void		dispatch_apply_f(int i,DQ q,void *d,void &m(void*,size_t));
	void		dispatch_async(DQ q,void ^b());
	void		dispatch_async_f(DQ q,void *d,void &m(void*));
    int         dispatch_block_wait(Dblock block,Dtime timeOut);
	DQ			dispatch_get_global_queue(int p,int f);
	void		dispatch_group_async(Dgroup g,DQ q,void ^b());
	void		dispatch_group_async_f(Dgroup g,DQ q,void *d,void &m(void*));
	Dgroup		dispatch_group_create();
	DQ			dispatch_queue_create(String s,int i);
	void		dispatch_group_notify(Dgroup g,DQ q,void ^b());
	void		dispatch_group_notify_f(Dgroup g,DQ q,void *d,void &m(void*));
	int			dispatch_group_wait(Dgroup g,Dtime);
	void		dispatch_release(Dgroup g);
	unsigned int	dispatch_time(unsigned int w,int d);
	alias
		delay		dispatch_time
		getQ		dispatch_get_global_queue
		makeGroup	dispatch_group_create
		makeQ		dispatch_queue_create
		letGo		dispatch_release
		waitOn		dispatch_group_wait
		;
}

